# ── PlayScope Environment Variables ──

# Backend
DATABASE_URL=postgresql+asyncpg://playscope:playscope@localhost:5432/playscope
DATABASE_SYNC_URL=postgresql://playscope:playscope@localhost:5432/playscope
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
UPLOAD_DIR=./storage/uploads
RESULTS_DIR=./storage/results
AI_ENGINE_URL=http://localhost:8001
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
DEBUG=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Database
POSTGRES_DB=playscope
POSTGRES_USER=playscope
POSTGRES_PASSWORD=playscope

# AWS S3 (optional — for production storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=playscope-storage
